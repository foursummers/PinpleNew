{
  "name": "pinple-new",
  "version": "1.0.0",
  "description": "拼朋友 — 信任圈社交 + 技能共享市场",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "npm run build:client && npm run build:api",
    "build:client": "vite build",
    "build:api": "esbuild server/vercel-handler.ts --bundle --platform=node --format=esm --target=node20 --packages=external --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --outfile=api/index.js",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
  },
  "dependencies": {
    "@trpc/client": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "axios": "^1.12.0",
    "cheerio": "^1.2.0",
    "cookie": "^1.0.2",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "jose": "6.1.0",
    "mysql2": "^3.15.0",
    "nanoid": "^5.1.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "superjson": "^1.13.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "typescript": "5.9.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.4"
  }
}
