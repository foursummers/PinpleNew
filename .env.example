# ── 必需 ────────────────────────────────────────────────────────────────
# MySQL 连接串
DATABASE_URL=mysql://user:pass@localhost:3306/pinple

# JWT / Cookie 签名密钥（任意 ≥ 32 字符长字符串）
JWT_SECRET=change-me-to-a-long-random-string

# ── OAuth / Manus 代理（当前产品未启用 Google 登录，可留空）─────────────
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# ── 邮件服务（用于找回密码）─────────────────────────────────────────────
# 可选。未配置时后端会把重置链接直接返回给前端做过渡（仅限非正式环境使用）。
# 推荐使用 Resend：https://resend.com  免费额度足够个人项目
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pinple <onboarding@resend.dev>
